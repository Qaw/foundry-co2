{{log "Chroniques Oubliées | hbs | attack-card" this}}
<div class="co chat-card roll-card attack-card" data-actor-id="{{actorId}}">
  <header class="card-header flexcol">
    <details class="attack-details">
      <summary>
        <div class="attack-item-card" data-tooltip="{{flavor}}" data-tooltip-direction="LEFT">
          {{#if itemImg}}
            <img class="attack-item-image" src="{{itemImg}}" alt="{{itemName}}" />
          {{/if}}
          <div class="attack-item-text">
            <div class="attack-item-name">{{itemName}}</div>
            {{#if actionName}}
              <div class="attack-item-subtitle">{{actionName}}</div>
            {{/if}}
          </div>
          <div class="attack-item-icon-block">
            {{#if hasDice}}
              <span class="attack-item-icon" data-tooltip="{{diceType}}" data-tooltip-direction="UP"><i class="fa-solid fa-dice"></i></span>
            {{/if}}
            {{#if hasTactical}}
              <span class="attack-item-icon" data-tooltip="{{tactical}}" data-tooltip-direction="UP"><i class="fa-solid fa-sliders-up"></i></span>
            {{/if}}
          </div>
        </div>
      </summary>
      <div class="attack-details-content">
        <section class="options">
          {{#if hasDice}}
            <strong class="display-dice-type"><i class="fa-solid fa-dice"></i> {{diceType}}&nbsp;&nbsp;</strong>
          {{/if}}
          {{#if hasTactical}}
            <strong class="display-tactical"><i class="fa-solid fa-sliders-up"></i> {{tactical}}</strong>
          {{/if}}
        </section>
        <div class="dice-roll" data-action="expandRoll">
          <div class="dice-result">
            <div class="dice-formula" data-tooltip="{{formulaAttackTooltip}}" data-tooltip-direction="UP">{{localize "CO.ui.formula"}} : {{formula}}</div>
            {{{tooltip}}}
          </div>
          {{#if showDifficulty}}
            {{#if opposeResult}}
              <div class="dice-result">
                <div class="dice-formula">{{localize "CO.ui.oppositeFormula"}} : {{opposeResult}}</div>
                {{{opposeTooltip}}}
              </div>
            {{/if}}
          {{/if}}
        </div>
      </div>
    </details>
  </header>

  <div class="card-content">
    <section class="bloc-result{{#if hasTargetResults}} has-target-results{{/if}}">
      <section class="result">
        <div class="attack-total-group">
          <div class="form-group total-text">
            <div>{{localize 'CO.ui.total'}} : </div>
          </div>
          <div class="form-group total-result">
            <div data-tooltip="{{localize 'CO.ui.total'}}" data-tooltip-direction="UP">{{total}}</div>
          </div>
          {{#if canUseLuckyPoints}}
            <div class="lucky-points">
              <a class="lp-button-attack">
                <i class="fa-regular fa-clover" data-tooltip="{{localize 'CO.dialogs.spendLuckyPoint'}}" data-tooltip-direction="UP"></i>
              </a>
            </div>
          {{/if}}
        </div>

        {{#unless hasTargetResults}}
          {{#if showDifficulty}}
            {{#if (eq difficulty "")}}{{else}}
              <div class="vs"><label>VS</label></div>
              <div class="form-group diff-result">
                {{#if oppositeRoll}}
                  <i class="fa-solid fa-square-question"></i>
                {{else}}
                  <div data-tooltip="{{localize 'CO.label.long.difficulty'}}" data-tooltip-direction="UP">{{difficulty}}</div>
                {{/if}}
              </div>
            {{/if}}
          {{/if}}
        {{/unless}}
      </section>
      {{#unless hasTargetResults}}
        <section class="result-sentence">
          {{#if oppositeRoll}}
            <button class="opposite-roll" data-opposite-value="{{difficulty}}" data-opposite-target="{{oppositeTarget}}" data-tooltip="{{localize 'CO.ui.oppositeRoll'}}{{#if oppositeAbilityLabel}} : {{oppositeAbilityLabel}}{{/if}}" data-tooltip-direction="UP">{{localize "CO.ui.oppositeRoll"}}</button>
          {{else}}
            {{#if showDifficulty}}
              {{#if isSuccess}}
                {{#if isCritical}}
                  <div class="show-result success critical"><i class="fas fa-check-double"></i><br /><strong>{{localize "CO.roll.critical"}}</strong></div>
                {{else}}
                  <div class="show-result success"><i class="fas fa-check"></i><br /><strong>{{localize "CO.roll.success"}}</strong></div>
                {{/if}}
              {{/if}}
              {{#if isFailure}}
                {{#if isFumble}}
                  <div class="show-result failure fumble"><i class="fas fa-skull-crossbones"></i><br /><strong>{{localize "CO.roll.fumble"}}</strong></div>
                {{else}}
                  <div class="show-result failure"><i class="fas fa-times"></i><br /><strong>{{localize "CO.roll.failure"}}</strong></div>
                {{/if}}
              {{/if}}
            {{/if}}
          {{/if}}
        </section>
      {{/unless}}
    </section>
    <section class="targets">
      {{#if hasTargetResults}}
        <details class="targets-collapsible" open>
          <summary class="targets-header"><i class="fa-solid fa-bullseye-arrow"></i> {{localize "CO.ui.targets"}}</summary>
          <ul class="target-list">
            {{#each targetResults as |target|}}
              <li class="target-row" data-target-uuid="{{target.uuid}}">
                {{#if @root.showDifficulty}}
                  {{#if target.needsOppositeRoll}}
                    <span class="target-outcome pending" data-tooltip="{{localize 'CO.ui.oppositeRoll'}}{{#if @root.oppositeAbilityLabel}} : {{@root.oppositeAbilityLabel}}{{/if}}" data-tooltip-direction="LEFT"><i class="fas fa-question"></i></span>
                  {{else}}
                      {{#if target.isCritical}}
                        <span class="target-outcome success critical" data-tooltip="{{localize 'CO.roll.critical'}}" data-tooltip-direction="LEFT"><i class="fas fa-check-double"></i></span>
                      {{else if target.isFumble}}
                        <span class="target-outcome failure fumble" data-tooltip="{{localize 'CO.roll.fumble'}}" data-tooltip-direction="LEFT"><i class="fas fa-skull-crossbones"></i></span>
                      {{else if target.isSuccess}}
                        <span class="target-outcome success" data-tooltip="{{localize 'CO.roll.success'}}" data-tooltip-direction="LEFT"><i class="fas fa-check"></i></span>
                      {{else if target.isFailure}}
                        <span class="target-outcome failure" data-tooltip="{{localize 'CO.roll.failure'}}" data-tooltip-direction="LEFT"><i class="fas fa-times"></i></span>
                      {{/if}}
                  {{/if}}
                {{/if}}
                {{#if target.img}}
                  <img class="target-portrait" src="{{target.img}}" data-tooltip="{{target.name}}" height="32" width="32" />
                {{/if}}
                <span class="target-name">{{target.name}}</span>
                {{#if target.needsOppositeRoll}}
                  <button class="opposite-roll" data-opposite-value="{{../oppositeValue}}" data-opposite-target="{{target.uuid}}" data-tooltip="{{localize 'CO.ui.oppositeRoll'}}{{#if @root.oppositeAbilityLabel}} : {{@root.oppositeAbilityLabel}}{{/if}}" data-tooltip-direction="UP">{{localize "CO.ui.oppositeRoll"}}</button>
                {{else}}
                  {{#if @root.showDifficulty}}
                    <span class="target-difficulty display-difficulty" data-tooltip="{{localize 'CO.label.long.difficulty'}}" data-tooltip-direction="UP"><i class="fas fa-shield-halved"></i> {{target.difficulty}}</span>
                  {{/if}}
                  {{#if target.opposeHasLuckyPoints}}
                    {{#if target.isSuccess}}
                      {{#unless target.isCritical}}
                        <a class="lp-button-oppose-target" data-target-uuid="{{target.uuid}}" data-actor-id="{{target.opposeActorId}}">
                          <i class="fa-regular fa-clover" data-tooltip="{{localize 'CO.dialogs.spendLuckyPoint'}}" data-tooltip-direction="UP"></i>
                        </a>
                      {{/unless}}
                    {{/if}}
                  {{/if}}
                {{/if}}
              </li>
            {{/each}}
          </ul>
        </details>
      {{/if}}
    </section>    
  </div>

  <footer class="card-footer">
  </footer>

</div>